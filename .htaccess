RewriteEngine On

# Wymuszenie HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://plikdruk.pl%{REQUEST_URI} [L,R=301]

# Usunięcie www
RewriteCond %{HTTP_HOST} ^www\.plikdruk\.pl$ [NC]
RewriteRule ^ https://plikdruk.pl%{REQUEST_URI} [L,R=301]

# Usunięcie index.html
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^index\.html$ https://plikdruk.pl/ [R=301,L]

# Kompresja GZIP
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>

# Cache statycznych plików
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType image/jpg "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType text/css "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
</IfModule>

# Blokada dostępu do .htaccess
<Files .htaccess>
Require all denied
</Files>