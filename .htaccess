RewriteEngine On
Options +FollowSymLinks

# ============================================
# WYMUSZENIE HTTPS + KANONICZNY URL
# ============================================

# 1. Usuń www i wymuś HTTPS w jednym skoku
RewriteCond %{HTTP_HOST} ^www\.plikdruk\.pl$ [NC]
RewriteRule ^(.*)$ https://plikdruk.pl/$1 [R=301,L]

# 2. Wymuś HTTPS (bez www już obsłużone wyżej)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://plikdruk.pl/$1 [R=301,L]

# 3. Usuń index.html, index.htm, index.php
RewriteCond %{THE_REQUEST} \s/+(index|default)\.(html?|php)[\s?] [NC]
RewriteRule ^(.*)index\.(html?|php)$ https://plikdruk.pl/$1 [R=301,L,NC]

# ============================================
# KOMPRESJA
# ============================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json application/xml text/javascript
  AddOutputFilterByType DEFLATE image/svg+xml application/rss+xml application/atom+xml
</IfModule>

# ============================================
# CACHE
# ============================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"

  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
</IfModule>

# ============================================
# NAGŁÓWKI CACHE
# ============================================
<IfModule mod_headers.c>
  <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg|css|js|woff|woff2|ttf|otf)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>

  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "max-age=86400, public, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================
# BLOKADA
# ============================================
<Files .htaccess>
  Require all denied
</Files>

<Files "send-mail.php">
  Require all denied
</Files>

<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak|config)$">
  Require all denied
</FilesMatch>