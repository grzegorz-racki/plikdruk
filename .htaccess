RewriteEngine On
Options +FollowSymLinks

# ============================================
# WYMUSZENIE HTTPS + KANONICZNY URL
# ============================================

# 1. Najpierw wymuś HTTPS dla wszystkiego
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://plikdruk.pl/$1 [R=301,L]

# 2. Usuń www (jeśli ktoś ma www)
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# 3. Usuń index.html, index.htm, index.php
RewriteCond %{THE_REQUEST} \s/+(index|default)\.(html?|php)[\s?] [NC]
RewriteRule ^(.*)index\.(html?|php)$ https://plikdruk.pl/$1 [R=301,L,NC]

# 4. Usuń końcowy slash dla plików (ale zostaw dla katalogów)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} /(.*)/$
RewriteRule ^ /%1 [R=301,L]

# 5. Dodaj końcowy slash dla katalogów (jeśli brak)
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.*)$ /$1/ [R=301,L]

# ============================================
# KOMPRESJA
# ============================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json application/xml text/javascript
  AddOutputFilterByType DEFLATE image/svg+xml application/rss+xml application/atom+xml
</IfModule>

# ============================================
# CACHE
# ============================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  
  # Obrazki
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # CSS, JS
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
</IfModule>

# ============================================
# NAGŁÓWKI CACHE
# ============================================
<IfModule mod_headers.c>
  <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg|css|js|woff|woff2|ttf|otf)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>
  
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "max-age=86400, private, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================
# BLOKADA
# ============================================
<Files .htaccess>
  Require all denied
</Files>

<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak|config)$">
  Require all denied
</FilesMatch>